<%- include('partials/header', { title: 'Mes fiches de paie', active: 'paie' }) %>

<div class="card">
  <h3>Mes fiches de paie</h3>
  <p style="font-size:12.5px;color:#9AA7B5;margin:0 0 18px;">Classées de la plus récente à la plus ancienne.</p>
  <% if (fiches.length === 0) { %>
    <div class="empty-state">Aucune fiche déposée pour l'instant.</div>
  <% } else { %>
    <% fiches.forEach(function(p) { %>
      <div class="row-flex" style="padding:14px 16px;border:1px solid #EDF0F4;border-radius:12px;margin-bottom:10px;">
        <div style="width:42px;height:42px;border-radius:10px;background:#EAF1F8;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2E5C8A" stroke-width="1.8"><path d="M6 3h8l4 4v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"></path><path d="M14 3v4h4M8.5 12.5h7M8.5 16h7"></path></svg>
        </div>
        <div style="flex:1;">
          <div style="font-size:14.5px;font-weight:700;"><%= formatPeriode(p.periode) %></div>
          <div style="font-size:12px;color:#9AA7B5;">Déposée le <%= formatDate(p.date_depot) %> · PDF</div>
        </div>
        <a href="/paie/<%= p.id %>/telecharger" class="btn btn-outline">Télécharger</a>
      </div>
    <% }); %>
  <% } %>
</div>

<%- include('partials/footer') %>
