<%- include('partials/header', { title: 'Mon planning', active: 'planning' }) %>

<div class="card">
  <div style="display:flex;align-items:center;justify-content:flex-end;margin-bottom:10px;">
    <button type="button" class="btn btn-outline" id="btn-selectionner" onclick="toggleSelectionMode()">Sélectionner</button>
  </div>
  <div id="selection-bar" style="display:none;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;background:#EAF1F8;border:1px solid #CFDBE8;border-radius:10px;padding:10px 14px;margin-bottom:14px;">
    <span style="font-size:13px;color:#244B70;font-weight:600;" id="selection-hint">Cliquez sur le premier jour de votre demande de congé.</span>
    <div style="display:flex;gap:8px;">
      <button type="button" class="btn btn-outline" onclick="annulerSelection()">Annuler</button>
      <button type="button" class="btn btn-primary" id="btn-confirmer-selection" style="display:none;" onclick="confirmerSelection()">Demander un congé</button>
    </div>
  </div>

  <%- include('partials/calendar-grid', { weeks, monthLabel, prevMois, nextMois, baseUrl: '/planning', alternantId, mois, selectable: true }) %>

  <div style="margin-top:16px;font-size:12.5px;color:#9AA7B5;display:flex;align-items:center;gap:8px;">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v5M12 16h.01"></path></svg>
    Le planning est géré par votre administrateur. Utilisez « Sélectionner » pour demander un congé sur une période.
  </div>
</div>

<div id="modal-ajouter-conge" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-box-header">
      <h3 style="margin:0;">Nouvelle demande</h3>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-ajouter-conge').style.display='none'">✕</button>
    </div>
    <form method="POST" action="/conges">
      <%- include('partials/range-input', { debutName: 'date_debut', finName: 'date_fin' }) %>
      <label>Type de congé</label>
      <%- include('partials/select-field', { name: 'type', value: 'paye', options: [
        { value: 'paye', label: 'Congé payé' },
      ].concat(profile.heures_eligible ? [{ value: 'recuperation', label: 'Heure de récupération' }] : []).concat([
        { value: 'sans_solde', label: 'Sans solde' }
      ]) }) %>
      <label>Commentaire (optionnel)</label>
      <textarea name="commentaire" rows="3"></textarea>
      <button class="btn btn-primary" type="submit" style="width:100%;">Envoyer la demande</button>
    </form>
  </div>
</div>

<script>
  (function () {
    var selectionMode = false;
    var start = null, end = null;

    window.toggleSelectionMode = function () {
      selectionMode = !selectionMode;
      window.__calendarSelectionMode = selectionMode;
      document.getElementById('btn-selectionner').textContent = selectionMode ? 'Quitter la sélection' : 'Sélectionner';
      document.getElementById('selection-bar').style.display = selectionMode ? 'flex' : 'none';
      if (!selectionMode) annulerSelection();
    };

    window.annulerSelection = function () {
      start = null; end = null;
      document.querySelectorAll('.js-day-cell').forEach(function (c) { c.classList.remove('day-selected', 'day-in-range'); });
      document.getElementById('selection-hint').textContent = 'Cliquez sur le premier jour de votre demande de congé.';
      document.getElementById('btn-confirmer-selection').style.display = 'none';
    };

    function refreshHighlight() {
      document.querySelectorAll('.js-day-cell').forEach(function (c) {
        var d = c.dataset.date;
        var selected = d === start || d === end;
        var inRange = start && end && d > start && d < end;
        c.classList.toggle('day-selected', !!selected);
        c.classList.toggle('day-in-range', !!inRange);
      });
    }

    document.addEventListener('click', function (e) {
      if (!selectionMode) return;
      var cell = e.target.closest ? e.target.closest('.js-day-cell') : null;
      if (!cell) return;
      if (cell.dataset.ferie === '1') return;
      var date = cell.dataset.date;

      if (!start || (start && end)) {
        start = date; end = null;
      } else if (date < start) {
        start = date;
      } else {
        end = date;
      }
      refreshHighlight();
      document.getElementById('selection-hint').textContent = !end
        ? 'Cliquez sur le dernier jour (ou recliquez sur le même jour pour une demande d’un seul jour).'
        : 'Période sélectionnée : cliquez sur « Demander un congé » pour continuer.';
      document.getElementById('btn-confirmer-selection').style.display = start ? 'inline-block' : 'none';
    });

    window.confirmerSelection = function () {
      if (!start) return;
      var modal = document.getElementById('modal-ajouter-conge');
      var finale = end || start;
      modal.querySelector('.range-value-start').value = start;
      modal.querySelector('.range-value-end').value = finale;
      modal.querySelector('.range-start').value = start.split('-').reverse().join('/');
      modal.querySelector('.range-end').value = finale.split('-').reverse().join('/');
      modal.style.display = 'flex';
    };
  })();
</script>

<%- include('partials/footer') %>
