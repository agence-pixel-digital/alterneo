<%- include('partials/header', { title: "Absences école", active: 'ecole' }) %>

<% if (error) { %><div class="error"><%= error %></div><% } %>
<% const motifLabels = { maladie: 'Maladie', justifie_ecole: "Justifié auprès de l'école", sans_solde: 'Sans solde', conge_paye: 'Congé payé' }; %>

<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <h3 style="margin:0;">Mon historique</h3>
    <button type="button" class="btn btn-primary" onclick="document.getElementById('modal-ajouter-absence').style.display='flex'">+ Ajouter</button>
  </div>
  <% if (absences.length === 0) { %>
    <div class="empty-state">Aucune absence signalée.</div>
  <% } else { %>
    <% absences.forEach(function(e) { %>
      <div class="list-row">
        <div style="flex:1;font-size:13.5px;font-weight:600;"><%= formatDate(e.date) %><% if (e.heures) { %> · <%= e.heures %>h (<%= Math.round(e.heures / HEURES_PAR_JOUR * 10) / 10 %> j)<% } %></div>
        <div style="flex:1.4;font-size:12.5px;color:#9AA7B5;">
          <%= motifLabels[e.motif_type] || e.motif_type %><% if (e.motif) { %> · <%= e.motif %><% } %>
        </div>
        <% if (e.justificatif_url) { %>
          <a href="/ecole/<%= e.id %>/justificatif" style="font-size:12px;color:#2E5C8A;font-weight:600;">Certificat</a>
        <% } else { %>
          <div style="flex:1;text-align:right;font-size:12px;color:#7A53C1;font-weight:600;">Signalée</div>
        <% } %>
      </div>
    <% }); %>
  <% } %>
</div>

<div id="modal-ajouter-absence" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-box-header">
      <h3 style="margin:0;">Déclarer une absence école</h3>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-ajouter-absence').style.display='none'">✕</button>
    </div>
    <p style="font-size:12.5px;color:#9AA7B5;margin:0 0 18px;">Signalez un jour où vous n'avez pas pu assister aux cours. Votre administrateur en sera informé.</p>
    <form method="POST" action="/ecole" enctype="multipart/form-data">
      <div class="grid-2">
        <div><label>Date</label><%- include('partials/date-input', { name: 'date' }) %></div>
        <div><label>Nombre d'heures</label><input type="number" name="heures" step="0.5" min="0" placeholder="Laisser vide = journée complète (<%= HEURES_PAR_JOUR %>h)"></div>
      </div>
      <label>Motif</label>
      <%- include('partials/select-field', {
        name: 'motif_type', id: 'motif_type', placeholder: 'Sélectionner un motif',
        options: Object.keys(motifLabels).map(k => ({ value: k, label: motifLabels[k] }))
      }) %>
      <div id="bloc-justificatif" style="display:none;">
        <label>Certificat médical (optionnel)</label>
        <div class="upload-zone">
          <input type="file" name="justificatif" accept="application/pdf,image/png,image/jpeg">
          <span>PDF ou photo, max 5 Mo</span>
        </div>
      </div>
      <label>Précision (optionnel)</label>
      <textarea name="motif" rows="2" placeholder="ex. Grève des transports…"></textarea>
      <button class="btn" type="submit" style="width:100%;background:#7A53C1;color:#fff;">Déclarer l'absence</button>
    </form>
    <script>
      document.getElementById('motif_type').addEventListener('change', function () {
        document.getElementById('bloc-justificatif').style.display = this.value === 'maladie' ? 'block' : 'none';
      });
    </script>
  </div>
</div>

<%- include('partials/footer') %>
