<%- include('partials/header', { title: 'Missions', active: 'missions' }) %>

<% if (error) { %><div class="error"><%= error %></div><% } %>

<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;margin-bottom:6px;">
    <h3 style="margin:0;">Missions</h3>
    <button type="button" class="btn btn-primary" onclick="document.getElementById('modal-ajouter-mission').style.display='flex'">+ Ajouter</button>
  </div>
  <form method="GET" action="/missions" class="inline-filter-bar" style="margin-bottom:18px;">
    <div style="width:190px;">
      <%- include('partials/select-field', {
        name: 'alt', value: filtreAlt, placeholder: 'Tous les alternants',
        options: [{ value: '', label: 'Tous les alternants' }].concat(alternants.map(a => ({ value: a.id, label: a.prenom + ' ' + a.nom })))
      }) %>
    </div>
    <div style="width:150px;"><%- include('partials/month-input', { name: 'mois', value: filtreMois }) %></div>
    <button class="btn btn-outline" type="submit">Filtrer</button>
    <% if (filtreAlt || filtreMois) { %><a href="/missions" class="btn btn-outline">Réinitialiser</a><% } %>
  </form>
  <% if (missions.length === 0) { %>
    <div class="empty-state">Aucune mission pour l'instant.</div>
  <% } else { %>
    <% missions.forEach(function(m) { %>
      <div class="list-row">
        <div class="avatar" style="background:<%= m.profiles.avatar_color %>;"><%= (m.profiles.prenom[0] + m.profiles.nom[0]).toUpperCase() %></div>
        <div style="flex:1.2;font-size:13.5px;font-weight:600;"><%= m.profiles.prenom %> <%= m.profiles.nom %></div>
        <div style="flex:1.3;font-size:13.5px;font-weight:600;"><%= m.titre %></div>
        <div style="flex:1;font-size:13px;color:#5B6B7D;"><%= formatDate(m.date_debut) %> → <%= formatDate(m.date_fin) %></div>
        <div style="flex:1.6;font-size:12.5px;color:#9AA7B5;"><%= m.description || '—' %></div>
        <button type="button" class="btn btn-outline"
          data-id="<%= m.id %>"
          data-alternant-id="<%= m.alternant_id %>"
          data-titre="<%= m.titre %>"
          data-description="<%= m.description || '' %>"
          data-date-debut="<%= m.date_debut %>"
          data-date-fin="<%= m.date_fin %>"
          data-date-debut-fr="<%= formatDate(m.date_debut) %>"
          data-date-fin-fr="<%= formatDate(m.date_fin) %>"
          onclick="ouvrirModalModifierMission(this)">Modifier</button>
        <form method="POST" action="/missions/<%= m.id %>/supprimer" onsubmit="return confirm('Supprimer cette mission ?');">
          <button class="btn btn-outline" type="submit">Supprimer</button>
        </form>
      </div>
    <% }); %>
  <% } %>
</div>

<%- include('partials/missions-gantt', { gantt }) %>

<div id="modal-ajouter-mission" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-box-header">
      <h3 style="margin:0;">Ajouter une mission</h3>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-ajouter-mission').style.display='none'">✕</button>
    </div>
    <form method="POST" action="/missions">
      <label>Alternant</label>
      <%- include('partials/select-field', { name: 'alternant_id', options: alternants.map(a => ({ value: a.id, label: a.prenom + ' ' + a.nom })) }) %>
      <label>Titre de la mission</label>
      <input name="titre" required placeholder="ex. Refonte du site vitrine">
      <%- include('partials/range-input', { debutName: 'date_debut', finName: 'date_fin' }) %>
      <label>Description (optionnel)</label>
      <textarea name="description" rows="3" placeholder="Détails de la mission…"></textarea>
      <button class="btn btn-primary" type="submit" style="width:100%;">Ajouter</button>
    </form>
  </div>
</div>

<div id="modal-modifier-mission" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-box-header">
      <h3 style="margin:0;">Modifier la mission</h3>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-modifier-mission').style.display='none'">✕</button>
    </div>
    <form method="POST" action="">
      <label>Alternant</label>
      <%- include('partials/select-field', { name: 'alternant_id', options: alternants.map(a => ({ value: a.id, label: a.prenom + ' ' + a.nom })) }) %>
      <label>Titre de la mission</label>
      <input name="titre" required>
      <%- include('partials/range-input', { debutName: 'date_debut', finName: 'date_fin' }) %>
      <label>Description (optionnel)</label>
      <textarea name="description" rows="3"></textarea>
      <button class="btn btn-primary" type="submit" style="width:100%;">Enregistrer</button>
    </form>
  </div>
</div>

<script>
  function ouvrirModalModifierMission(btn) {
    var d = btn.dataset;
    var modal = document.getElementById('modal-modifier-mission');
    modal.querySelector('form').action = '/missions/' + d.id;

    var hidden = modal.querySelector('.select-value');
    var label = modal.querySelector('.select-label');
    hidden.value = d.alternantId;
    modal.querySelectorAll('.select-option').forEach(function (o) {
      var match = o.dataset.value === d.alternantId;
      o.classList.toggle('selected', match);
      if (match) label.textContent = o.dataset.label;
    });

    modal.querySelector('input[name="titre"]').value = d.titre;
    modal.querySelector('textarea[name="description"]').value = d.description;

    modal.querySelector('.range-value-start').value = d.dateDebut;
    modal.querySelector('.range-value-end').value = d.dateFin;
    modal.querySelector('.range-start').value = d.dateDebutFr;
    modal.querySelector('.range-end').value = d.dateFinFr;

    modal.style.display = 'flex';
  }
</script>

<%- include('partials/footer') %>
