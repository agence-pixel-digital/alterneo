<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Mot de passe oublié - Alternéo</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="login-wrap">
    <div class="login-box">
      <h2 style="margin:0 0 6px;">Mot de passe oublié</h2>
      <p style="color:#6B7A8D;font-size:14px;margin:0 0 24px;">Indiquez votre e-mail, nous vous envoyons un lien de réinitialisation.</p>

      <% if (sent) { %>
        <div style="background:#E2F3EB;color:#15784F;padding:12px 14px;border-radius:10px;font-size:13.5px;margin-bottom:16px;">
          Si un compte existe avec cette adresse, un e-mail vient d'être envoyé.
        </div>
      <% } else { %>
        <% if (error) { %><div class="error"><%= error %></div><% } %>
        <form method="POST" action="/mot-de-passe-oublie">
          <label>Adresse e-mail</label>
          <input type="email" name="email" required>
          <button class="btn btn-primary" style="width:100%;" type="submit">Envoyer le lien</button>
        </form>
      <% } %>

      <div style="text-align:center;margin-top:20px;">
        <a href="/login" style="font-size:13px;color:#2E5C8A;font-weight:600;">Retour à la connexion</a>
      </div>
    </div>
  </div>
</body>
</html>
