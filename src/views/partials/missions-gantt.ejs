<% if (gantt) { %>
<div class="card">
  <h3>Planning des missions</h3>
  <div class="table-scroll">
  <div style="min-width:600px;">
    <div style="position:relative;height:22px;margin:0 0 10px 170px;border-bottom:1px solid #EAEDF2;">
      <% gantt.markers.forEach(function(mk) { %>
        <div style="position:absolute;left:<%= mk.leftPct %>%;top:0;font-size:11px;color:#9AA7B5;font-weight:600;border-left:1px solid #EAEDF2;padding-left:5px;white-space:nowrap;"><%= mk.label %></div>
      <% }); %>
    </div>
    <% gantt.lignes.forEach(function(ligne) { %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
        <div class="row-flex" style="width:160px;flex-shrink:0;">
          <div class="avatar" style="width:26px;height:26px;font-size:10px;background:<%= ligne.profile.avatar_color %>;"><%= (ligne.profile.prenom[0]+ligne.profile.nom[0]).toUpperCase() %></div>
          <div style="font-size:12.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= ligne.profile.prenom %> <%= ligne.profile.nom %></div>
        </div>
        <div style="position:relative;flex:1;height:30px;background:#F6F8FB;border-radius:8px;">
          <% ligne.items.forEach(function(it) { %>
            <div title="<%= it.titre %> (<%= formatDate(it.date_debut) %> → <%= formatDate(it.date_fin) %>)"
              style="position:absolute;top:4px;height:22px;left:<%= it.leftPct %>%;width:<%= it.widthPct %>%;background:#2E5C8A;border-radius:6px;display:flex;align-items:center;padding:0 8px;overflow:hidden;">
              <span style="color:#fff;font-size:11px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= it.titre %></span>
            </div>
          <% }); %>
        </div>
      </div>
    <% }); %>
  </div>
  </div>
</div>
<% } %>
