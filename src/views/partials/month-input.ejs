<div class="date-field month-field">
  <input type="text" class="date-display" placeholder="Mois AAAA" autocomplete="off" readonly
    value="<%= locals.value ? formatPeriode(locals.value) : '' %>">
  <svg class="date-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M3 10h18M8 3v4M16 3v4"></path></svg>
  <input type="hidden" name="<%= name %>" class="month-value" value="<%= locals.value || '' %>">
</div>
