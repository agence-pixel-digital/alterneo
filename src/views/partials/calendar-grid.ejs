<div id="planning-calendar">
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:14px;">
  <div style="display:flex;align-items:center;gap:14px;">
    <% const sep = baseUrl.includes('?') ? '&' : '?'; %>
    <a href="<%= baseUrl %><%= sep %>mois=<%= prevMois %>#planning-calendar" class="btn btn-outline">‹</a>
    <span style="font-size:15px;font-weight:700;min-width:150px;text-align:center;"><%= monthLabel %></span>
    <a href="<%= baseUrl %><%= sep %>mois=<%= nextMois %>#planning-calendar" class="btn btn-outline">›</a>
  </div>
  <div class="legend">
    <div class="legend-item"><span class="type-dot dot-entreprise"></span>Entreprise</div>
    <div class="legend-item"><span class="type-dot dot-ecole"></span>École</div>
    <div class="legend-item"><span class="type-dot dot-conge"></span>Congé / Récup.</div>
    <div class="legend-item"><span class="type-dot dot-absent"></span>Absent</div>
    <div class="legend-item"><span class="type-dot dot-ferie"></span>Férié</div>
  </div>
</div>

<div class="calendar-grid" style="margin-bottom:8px;">
  <% ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'].forEach(function(d) { %>
    <div style="text-align:center;font-size:11px;font-weight:700;color:#9AA7B5;text-transform:uppercase;"><%= d %></div>
  <% }); %>
</div>

<% weeks.forEach(function(week) { %>
  <div class="calendar-grid" style="margin-bottom:8px;">
    <% week.forEach(function(cell) { %>
      <% if (!cell) { %>
        <div class="calendar-cell empty"></div>
      <% } else { %>
        <% const editableJour = locals.dayEditable && cell.inContract && cell.type !== 'ferie'; %>
        <div class="calendar-cell <%= !cell.inContract ? 'out-of-contract' : (cell.type ? 'type-'+cell.type : '') %> <%= cell.today ? 'today' : '' %> <%= locals.selectable ? 'js-day-cell' : '' %>" data-date="<%= cell.key %>" data-ferie="<%= cell.type === 'ferie' ? '1' : '' %>"
          <% if (editableJour) { %>
            data-type="<%= cell.type || '' %>" data-modalite="<%= cell.modalite || '' %>" data-commentaire="<%= cell.commentaire || '' %>" data-date-fr="<%= formatDate(cell.key) %>"
            style="cursor:pointer;" onclick="if(!window.__calendarSelectionMode){ouvrirModalJour(this);}"
          <% } %>
        >
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:4px;">
            <span class="num"><%= cell.day %></span>
            <button type="button" class="day-note-btn <%= cell.commentaire ? 'has-note' : '' %>"
              data-date="<%= cell.key %>" data-date-fr="<%= formatDate(cell.key) %>" data-commentaire="<%= cell.commentaire || '' %>"
              onclick="if(!window.__calendarSelectionMode){event.stopPropagation();ouvrirModalCommentaireJour(this);}" title="Note du jour">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path></svg>
            </button>
          </div>
          <% if (cell.type) { %>
            <span class="tag">
              <span class="type-dot dot-<%= cell.type %>"></span><span class="tag-label"><%= { entreprise:'Entreprise', ecole:'École', conge:'Congé', recuperation:'Récup.', absent:'Absent', ferie:'Férié' }[cell.type] %></span>
              <% if (cell.modalite === 'presentiel') { %>
                <span class="modalite-icon" title="Présentiel"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg></span>
              <% } else if (cell.modalite === 'distanciel') { %>
                <span class="modalite-icon" title="Distanciel"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg></span>
              <% } %>
            </span>
          <% } %>
          <% if (cell.commentaire) { %>
            <div class="day-note-preview" data-date="<%= cell.key %>" data-date-fr="<%= formatDate(cell.key) %>" data-commentaire="<%= cell.commentaire %>"
              onclick="if(!window.__calendarSelectionMode){event.stopPropagation();ouvrirModalCommentaireJour(this);}" title="<%= cell.commentaire %>"><%= cell.commentaire %></div>
          <% } %>
        </div>
      <% } %>
    <% }); %>
  </div>
<% }); %>
</div>

<div id="modal-commentaire-jour" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-box-header">
      <h3 style="margin:0;">Note du <span id="commentaire-jour-date"></span></h3>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-commentaire-jour').style.display='none'">✕</button>
    </div>
    <form method="POST" action="/planning/commentaire">
      <input type="hidden" name="alternant_id" value="<%= alternantId %>">
      <input type="hidden" name="date" id="commentaire-jour-date-input">
      <input type="hidden" name="retour" value="<%= baseUrl %><%= sep %>mois=<%= mois %>#planning-calendar">
      <textarea name="commentaire" id="commentaire-jour-textarea" rows="3" placeholder="ex. Prendre le matériel, Déplacement…"></textarea>
      <button class="btn btn-primary" type="submit" style="width:100%;margin-top:10px;">Enregistrer la note</button>
    </form>
  </div>
</div>
<script>
  function ouvrirModalCommentaireJour(btn) {
    var d = btn.dataset;
    document.getElementById('commentaire-jour-date').textContent = d.dateFr;
    document.getElementById('commentaire-jour-date-input').value = d.date;
    document.getElementById('commentaire-jour-textarea').value = d.commentaire;
    document.getElementById('modal-commentaire-jour').style.display = 'flex';
  }
</script>

<% if (locals.dayEditable) { %>
<div id="modal-jour" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-box-header">
      <h3 style="margin:0;">Modifier le <span id="jour-titre-date"></span></h3>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-jour').style.display='none'">✕</button>
    </div>
    <form method="POST" action="/planning/jour">
      <input type="hidden" name="alternant_id" value="<%= alternantId %>">
      <input type="hidden" name="date" id="jour-date-input">
      <input type="hidden" name="retour" value="<%= baseUrl %><%= sep %>mois=<%= mois %>#planning-calendar">
      <label>Type de jour</label>
      <%- include('select-field', { name: 'type', id: 'jour-type', value: 'entreprise', options: [
        { value: 'entreprise', label: 'Entreprise' },
        { value: 'ecole', label: 'École' },
        { value: 'conge', label: 'Congé' },
        { value: 'absent', label: 'Absent' }
      ] }) %>
      <div id="jour-conge-type-field">
        <label>Type de congé</label>
        <%- include('select-field', { name: 'conge_type', id: 'jour-conge-type', value: 'paye', options: [
          { value: 'paye', label: 'Congé payé' },
          { value: 'recuperation', label: 'Récupération' },
          { value: 'sans_solde', label: 'Sans solde' }
        ] }) %>
      </div>
      <div id="jour-modalite-field">
        <label>Modalité</label>
        <%- include('select-field', { name: 'modalite', id: 'jour-modalite', placeholder: 'Non précisé', options: [
          { value: 'presentiel', label: 'Présentiel' },
          { value: 'distanciel', label: 'Distanciel' }
        ] }) %>
      </div>
      <label>Note du jour</label>
      <textarea name="commentaire" id="jour-commentaire" rows="3" placeholder="ex. Prendre le matériel, Déplacement…"></textarea>
      <button class="btn btn-primary" type="submit" style="width:100%;margin-top:14px;">Enregistrer</button>
    </form>
  </div>
</div>
<script>
  (function () {
    // Met à jour un composant select-field depuis le JS (valeur cachée + libellé affiché).
    function setSelect(id, value, placeholderLabel) {
      var hidden = document.getElementById(id);
      var field = hidden.closest('.select-field');
      var opt = field.querySelector('.select-option[data-value="' + value + '"]');
      field.querySelectorAll('.select-option').forEach(function (o) { o.classList.remove('selected'); });
      if (!opt) {
        hidden.value = '';
        field.querySelector('.select-label').textContent = placeholderLabel || '';
        return;
      }
      hidden.value = opt.dataset.value;
      field.querySelector('.select-label').textContent = opt.dataset.label;
      opt.classList.add('selected');
    }

    function syncJourFields() {
      var type = document.getElementById('jour-type').value;
      document.getElementById('jour-conge-type-field').style.display = type === 'conge' ? 'block' : 'none';
      document.getElementById('jour-modalite-field').style.display = type === 'entreprise' ? 'block' : 'none';
    }
    document.getElementById('jour-type').addEventListener('change', syncJourFields);

    window.ouvrirModalJour = function (cell) {
      var d = cell.dataset;
      var type = d.type || 'entreprise';
      var congeType = 'paye';
      // La récupération est présentée comme un congé (sous-type « Récupération »).
      if (type === 'recuperation') { type = 'conge'; congeType = 'recuperation'; }
      document.getElementById('jour-titre-date').textContent = d.dateFr;
      document.getElementById('jour-date-input').value = d.date;
      setSelect('jour-type', type);
      setSelect('jour-conge-type', congeType);
      setSelect('jour-modalite', d.modalite || '', 'Non précisé');
      document.getElementById('jour-commentaire').value = d.commentaire || '';
      syncJourFields();
      document.getElementById('modal-jour').style.display = 'flex';
    };
  })();
</script>
<% } %>
