<% const soldeNegatif = solde.dispo < 0; %>
<div style="display:flex;align-items:baseline;gap:8px;margin-bottom:6px;">
  <span style="font-size:42px;font-weight:800;letter-spacing:-.02em;color:<%= soldeNegatif ? '#C2502E' : '#1F9D6B' %>;line-height:1;"><%= solde.dispo %></span>
  <span style="font-size:16px;font-weight:700;color:<%= soldeNegatif ? '#C2502E' : '#1F9D6B' %>;">jours disponibles</span>
</div>
<div class="progress-bar"><div style="width:<%= soldeNegatif ? 0 : (solde.acquis > 0 ? Math.min(100, Math.round(solde.pris / solde.acquis * 100)) : 0) %>%;background:<%= soldeNegatif ? '#C2502E' : '#1F9D6B' %>;"></div></div>
<div style="display:flex;justify-content:space-between;font-size:13px;">
  <div><span class="muted">Acquis : </span><strong><%= solde.acquis %> j</strong></div>
  <div><span class="muted">Pris : </span><strong><%= solde.pris %> j</strong></div>
</div>
<div style="margin-top:14px;font-size:12px;" class="muted">25 j / an (2,08 j / mois de contrat), disponibles dès le début du contrat.</div>

<% if (locals.heuresEligible) { %>
  <div style="margin-top:18px;padding-top:16px;border-top:1px solid #F1F4F8;display:flex;align-items:center;justify-content:space-between;">
    <div>
      <div style="font-size:13px;font-weight:700;">Heures de récupération</div>
      <div style="font-size:11.5px;color:#9AA7B5;margin-top:2px;">1 jour de récupération = <%= HEURES_PAR_JOUR %> h décomptées.</div>
    </div>
    <div style="font-size:20px;font-weight:800;color:#7A53C1;"><%= solde.heuresRecupDispo %> h</div>
  </div>
<% } %>
