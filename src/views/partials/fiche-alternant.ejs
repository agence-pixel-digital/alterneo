<div class="card">
  <div class="row-flex" style="margin-bottom:22px;">
    <div class="avatar" style="width:54px;height:54px;border-radius:13px;background:<%= alternant.avatar_color %>;font-size:18px;">
      <%= (alternant.prenom[0] + alternant.nom[0]).toUpperCase() %>
    </div>
    <div>
      <div style="font-size:18px;font-weight:800;"><%= alternant.prenom %> <%= alternant.nom %></div>
      <div style="font-size:13px;color:#7A8699;"><%= alternant.poste || '—' %></div>
    </div>
  </div>

  <div class="grid-3">
    <div style="background:#F8FAFC;border-radius:11px;padding:14px;">
      <div style="font-size:11.5px;color:#9AA7B5;font-weight:600;margin-bottom:4px;">E-MAIL</div>
      <div style="font-size:13.5px;font-weight:600;"><%= alternant.email %></div>
    </div>
    <div style="background:#F8FAFC;border-radius:11px;padding:14px;">
      <div style="font-size:11.5px;color:#9AA7B5;font-weight:600;margin-bottom:4px;">CONTRAT</div>
      <div style="font-size:13.5px;font-weight:600;"><%= formatDate(alternant.date_debut) %> – <%= formatDate(alternant.date_fin) %></div>
    </div>
    <div style="background:#F8FAFC;border-radius:11px;padding:14px;">
      <div style="font-size:11.5px;color:#9AA7B5;font-weight:600;margin-bottom:4px;">SOCIÉTÉ</div>
      <div style="font-size:13.5px;font-weight:600;"><%= (alternant.societes && alternant.societes.nom) || '—' %></div>
    </div>
  </div>

  <div style="background:#F8FAFC;border-radius:11px;padding:14px;margin-top:14px;">
    <div style="font-size:11.5px;color:#9AA7B5;font-weight:600;margin-bottom:4px;">HEURES SUPP.</div>
    <div style="font-size:13.5px;font-weight:700;color:#7A53C1;"><%= totalHeures %> h <span style="font-weight:500;color:#9AA7B5;">(≈ <%= Math.round(totalHeures / HEURES_PAR_JOUR * 10) / 10 %> j)</span></div>
  </div>

  <form method="POST" action="/alternants/<%= alternant.id %>/eligibilite" style="margin-top:14px;">
    <button type="submit" class="toggle-row" style="width:100%;border:0;text-align:left;cursor:pointer;">
      <div>
        <div style="font-size:13.5px;font-weight:700;">Éligible aux heures supplémentaires</div>
        <div style="font-size:12px;color:#9AA7B5;margin-top:2px;">Contrôle l'affichage de l'onglet « Mes heures » côté alternant.</div>
      </div>
      <span class="toggle <%= alternant.heures_eligible ? 'on' : '' %>"></span>
    </button>
  </form>
</div>

<div class="grid-2">
  <div class="card">
    <h3>Congés</h3>
    <%- include('compteur-conges', { solde, heuresEligible: alternant.heures_eligible }) %>
  </div>
  <div class="card">
    <h3>Heures supplémentaires</h3>
    <%- include('compteur-heures', { soldeHeures }) %>
  </div>
</div>

<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
    <h3 style="margin:0;">Planning</h3>
    <button type="button" class="btn btn-outline" id="btn-selectionner" onclick="toggleSelectionMode()">Sélectionner</button>
  </div>
  <div id="selection-bar" style="display:none;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;background:#EAF1F8;border:1px solid #CFDBE8;border-radius:10px;padding:10px 14px;margin-bottom:14px;">
    <span style="font-size:13px;color:#244B70;font-weight:600;" id="selection-hint">Cliquez sur le premier jour de la période à modifier.</span>
    <div style="display:flex;gap:8px;">
      <button type="button" class="btn btn-outline" onclick="annulerSelection()">Annuler</button>
      <button type="button" class="btn btn-primary" id="btn-confirmer-selection" style="display:none;" onclick="confirmerSelection()">Modifier cette période</button>
    </div>
  </div>

  <%- include('calendar-grid', Object.assign({ baseUrl: '/alternants?voir=' + alternant.id, alternantId: alternant.id, selectable: true, dayEditable: true }, grille)) %>
</div>

<div class="card">
  <h3>Modifier la fiche</h3>
  <form method="POST" action="/alternants/<%= alternant.id %>">
    <div class="grid-2">
      <div><label>Prénom</label><input name="prenom" required value="<%= alternant.prenom %>"></div>
      <div><label>Nom</label><input name="nom" required value="<%= alternant.nom %>"></div>
    </div>
    <label>E-mail</label>
    <input type="email" name="email" required value="<%= alternant.email %>">
    <label>Poste</label>
    <input name="poste" value="<%= alternant.poste || '' %>">
    <label>Société</label>
    <%- include('select-field', { name: 'societe_id', value: alternant.societe_id, placeholder: 'Aucune société', options: societes.map(s => ({ value: s.id, label: s.nom })) }) %>
    <div class="grid-2">
      <div><label>Début de contrat</label><%- include('date-input', { name: 'date_debut', value: alternant.date_debut }) %></div>
      <div><label>Fin de contrat</label><%- include('date-input', { name: 'date_fin', value: alternant.date_fin }) %></div>
    </div>
    <button class="btn btn-primary" type="submit" style="width:100%;">Enregistrer</button>
  </form>

  <div style="border-top:1px solid #F1F4F8;margin-top:20px;padding-top:20px;">
    <h4 style="margin:0 0 8px;font-size:14px;">Importer un planning (Excel)</h4>
    <p style="font-size:12.5px;color:#9AA7B5;margin:0 0 10px;">Téléchargez le modèle, complétez-le, puis reuploadez-le ici. Vous pourrez vérifier chaque ligne avant enregistrement.</p>
    <a href="/files/modele-planning.xlsx" download style="display:inline-flex;align-items:center;gap:7px;font-size:13px;font-weight:600;color:#2E5C8A;margin-bottom:14px;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 4v11M7 10l5 5 5-5"></path><path d="M5 20h14"></path></svg>
      Télécharger le modèle Excel
    </a>
    <form method="POST" action="/alternants/<%= alternant.id %>/planning-import" enctype="multipart/form-data">
      <div class="upload-zone">
        <input type="file" name="fichier" accept=".xlsx" required>
        <span>Fichier Excel (.xlsx), max 5 Mo</span>
      </div>
      <button class="btn btn-outline" type="submit" style="width:100%;">Analyser le fichier</button>
    </form>
  </div>
</div>

<div id="modal-modifier-periode" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-box-header">
      <h3 style="margin:0;">Modifier cette période</h3>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-modifier-periode').style.display='none'">✕</button>
    </div>
    <p style="font-size:13px;color:#7A8699;margin:0 0 14px;" id="periode-resume"></p>
    <form method="POST" action="/planning/periode">
      <input type="hidden" name="alternant_id" value="<%= alternant.id %>">
      <input type="hidden" name="debut" id="periode-debut">
      <input type="hidden" name="fin" id="periode-fin">
      <input type="hidden" name="retour" value="/alternants?voir=<%= alternant.id %>&mois=<%= grille.mois %>">
      <label>Type</label>
      <%- include('select-field', { name: 'type', value: 'entreprise', id: 'periode-type', options: [
        { value: 'entreprise', label: 'Entreprise' },
        { value: 'ecole', label: 'École' },
        { value: 'conge', label: 'Congé' },
        { value: 'recuperation', label: 'Heure de récupération' },
        { value: 'absent', label: 'Absent' }
      ] }) %>
      <div id="periode-modalite-field">
        <label>Modalité</label>
        <%- include('select-field', { name: 'modalite', placeholder: 'Non précisé', options: [
          { value: 'presentiel', label: 'Présentiel' },
          { value: 'distanciel', label: 'Distanciel' }
        ] }) %>
      </div>
      <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
        <input type="checkbox" name="jours_ouvres" checked style="width:auto;margin:0;">
        Jours ouvrés uniquement (exclut samedi/dimanche)
      </label>
      <button class="btn btn-primary" type="submit" style="width:100%;margin-top:14px;">Enregistrer</button>
    </form>
  </div>
</div>

<div class="card" style="border-color:#F0DAD0;">
  <h3 style="color:#9A3D22;">Zone de danger</h3>
  <p style="font-size:12.5px;color:#9AA7B5;margin:0 0 14px;">
    Supprime définitivement le compte de <%= alternant.prenom %> <%= alternant.nom %>, ainsi que tous ses congés,
    heures supplémentaires, fiches de paie, absences école et son planning. Cette action est irréversible.
  </p>
  <form method="POST" action="/alternants/<%= alternant.id %>/supprimer"
    onsubmit="return confirm('Supprimer définitivement ' + '<%= alternant.prenom %> <%= alternant.nom %>' + ' et toutes ses données ? Cette action est irréversible.');">
    <button class="btn" type="submit" style="background:#C2502E;color:#fff;">Supprimer cet alternant</button>
  </form>
</div>

<script>
  (function () {
    var selectionMode = false;
    var start = null, end = null;

    window.toggleSelectionMode = function () {
      selectionMode = !selectionMode;
      window.__calendarSelectionMode = selectionMode;
      document.getElementById('btn-selectionner').textContent = selectionMode ? 'Quitter la sélection' : 'Sélectionner';
      document.getElementById('selection-bar').style.display = selectionMode ? 'flex' : 'none';
      if (!selectionMode) annulerSelection();
    };

    window.annulerSelection = function () {
      start = null; end = null;
      document.querySelectorAll('.js-day-cell').forEach(function (c) { c.classList.remove('day-selected', 'day-in-range'); });
      document.getElementById('selection-hint').textContent = 'Cliquez sur le premier jour de la période à modifier.';
      document.getElementById('btn-confirmer-selection').style.display = 'none';
    };

    function refreshHighlight() {
      document.querySelectorAll('.js-day-cell').forEach(function (c) {
        var d = c.dataset.date;
        var selected = d === start || d === end;
        var inRange = start && end && d > start && d < end;
        c.classList.toggle('day-selected', !!selected);
        c.classList.toggle('day-in-range', !!inRange);
      });
    }

    document.addEventListener('click', function (e) {
      if (!selectionMode) return;
      var cell = e.target.closest ? e.target.closest('.js-day-cell') : null;
      if (!cell) return;
      if (cell.dataset.ferie === '1') return;
      var date = cell.dataset.date;

      if (!start || (start && end)) {
        start = date; end = null;
      } else if (date < start) {
        start = date;
      } else {
        end = date;
      }
      refreshHighlight();
      document.getElementById('selection-hint').textContent = !end
        ? 'Cliquez sur le dernier jour (ou recliquez sur le même jour pour un seul jour).'
        : 'Période sélectionnée : cliquez sur « Modifier cette période ».';
      document.getElementById('btn-confirmer-selection').style.display = start ? 'inline-block' : 'none';
    });

    window.confirmerSelection = function () {
      if (!start) return;
      var finale = end || start;
      document.getElementById('periode-debut').value = start;
      document.getElementById('periode-fin').value = finale;
      document.getElementById('periode-resume').textContent = 'Période : ' + start.split('-').reverse().join('/') + ' → ' + finale.split('-').reverse().join('/');
      document.getElementById('modal-modifier-periode').style.display = 'flex';
    };

    function syncModaliteVisibility() {
      var type = document.getElementById('periode-type').value;
      document.getElementById('periode-modalite-field').style.display = type === 'entreprise' ? 'block' : 'none';
    }
    document.getElementById('periode-type').addEventListener('change', syncModaliteVisibility);
    syncModaliteVisibility();
  })();
</script>
