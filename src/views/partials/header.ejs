<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Alternéo</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <a href="/dashboard" class="brand">
      <svg width="30" height="40" viewBox="0 0 1342.16 1769.44" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;"><polygon fill="#2E5C8A" points="0 357.38 356.51 0 1341.28 0.87 1342.16 827.49 981.71 1187.93 474.47 1187.93 474.47 899.14 544.81 828.8 911.37 828.8 983.68 756.49 983.68 360.88 436.03 360.88 359.13 437.77 359.13 1411.19 0.87 1769.44 0 357.38"/></svg>
      Alternéo
    </a>
    <% const icons = {
      dash: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="3" width="8" height="8" rx="1.5"></rect><rect x="13" y="3" width="8" height="8" rx="1.5"></rect><rect x="3" y="13" width="8" height="8" rx="1.5"></rect><rect x="13" y="13" width="8" height="8" rx="1.5"></rect></svg>',
      users: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="9" cy="8" r="3.2"></circle><path d="M2.5 20c0-3.6 2.9-6 6.5-6s6.5 2.4 6.5 6"></path><circle cx="17.5" cy="9" r="2.6"></circle><path d="M15.5 14.2c2.8.4 4.9 2.5 5 5.8"></path></svg>',
      sun: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="4.5"></circle><path d="M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"></path></svg>',
      school: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 4 2 9l10 5 10-5-10-5Z"></path><path d="M6 11.5V17c0 1.3 2.7 3 6 3s6-1.7 6-3v-5.5"></path></svg>',
      clock: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3.5 2"></path></svg>',
      doc: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M6 3h8l4 4v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"></path><path d="M14 3v4h4M8.5 12.5h7M8.5 16h7"></path></svg>',
      cal: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M3 10h18M8 3v4M16 3v4"></path></svg>',
      mail: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg>',
      gear: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>',
      list: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M9 6h11M9 12h11M9 18h11"></path><path d="m3 6 1.2 1.2L6.5 5"></path><path d="m3 12 1.2 1.2 2.3-2.2"></path><path d="m3 18 1.2 1.2 2.3-2.2"></path></svg>'
    }; %>
    <nav class="nav">
      <a href="/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>"><%- icons.dash %>Tableau de bord</a>
      <% if (profile.role === 'admin') { %>
        <a href="/alternants" class="<%= active === 'alternants' ? 'active' : '' %>"><%- icons.users %>Alternants</a>
        <a href="/planning" class="<%= active === 'planning' ? 'active' : '' %>"><%- icons.cal %>Planning</a>
        <a href="/missions" class="<%= active === 'missions' ? 'active' : '' %>"><%- icons.list %>Missions</a>
        <a href="/conges" class="<%= active === 'conges' ? 'active' : '' %>"><%- icons.sun %>Congés</a>
        <a href="/ecole" class="<%= active === 'ecole' ? 'active' : '' %>"><%- icons.school %>Absences école</a>
        <a href="/heures" class="<%= active === 'heures' ? 'active' : '' %>"><%- icons.clock %>Heures supp.</a>
        <a href="/paie" class="<%= active === 'paie' ? 'active' : '' %>"><%- icons.doc %>Fiches de paie</a>
        <a href="/envoi-comptable" class="<%= active === 'envoi-comptable' ? 'active' : '' %>"><%- icons.mail %>Envoi comptable</a>
      <% } else { %>
        <a href="/planning" class="<%= active === 'planning' ? 'active' : '' %>"><%- icons.cal %>Planning</a>
        <a href="/missions" class="<%= active === 'missions' ? 'active' : '' %>"><%- icons.list %>Missions</a>
        <a href="/ecole" class="<%= active === 'ecole' ? 'active' : '' %>"><%- icons.school %>Absences école</a>
        <a href="/conges" class="<%= active === 'conges' ? 'active' : '' %>"><%- icons.sun %>Congés</a>
        <% if (profile.heures_eligible) { %>
          <a href="/heures" class="<%= active === 'heures' ? 'active' : '' %>"><%- icons.clock %>Heures supp.</a>
        <% } %>
        <a href="/paie" class="<%= active === 'paie' ? 'active' : '' %>"><%- icons.doc %>Fiches de paie</a>
      <% } %>
    </nav>
  </aside>
  <div class="sidebar-backdrop"></div>
  <div class="main">
    <header class="topbar">
      <div style="display:flex;align-items:center;min-width:0;">
        <button type="button" class="mobile-menu-btn" aria-label="Ouvrir le menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"></path></svg>
        </button>
        <h1 style="min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= title %></h1>
      </div>
      <div class="topbar-user" style="position:relative;">
        <button type="button" class="topbar-user-btn row-flex" style="gap:12px;">
          <div style="text-align:right;">
            <div style="font-weight:700;font-size:14px;"><%= profile.prenom %> <%= profile.nom %></div>
            <div style="font-size:12.5px;color:#9AA7B5;">
              <%= profile.role === 'admin' ? 'Responsable RH' : ('Alternant' + (profile.poste ? ' · ' + profile.poste : '')) %>
            </div>
          </div>
          <div class="avatar" style="width:42px;height:42px;border-radius:12px;font-size:14px;background:<%= profile.avatar_color || '#2E5C8A' %>;">
            <%= (profile.prenom[0] + profile.nom[0]).toUpperCase() %>
          </div>
        </button>
        <div class="topbar-dropdown">
          <% if (profile.role === 'admin') { %>
            <a href="/parametres" class="topbar-dropdown-item">
              <%- icons.gear %>
              Paramètres
            </a>
          <% } %>
          <a href="/logout" class="topbar-dropdown-item danger">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><path d="M16 17l5-5-5-5"></path><path d="M21 12H9"></path></svg>
            Se déconnecter
          </a>
        </div>
      </div>
    </header>
    <div class="content">
