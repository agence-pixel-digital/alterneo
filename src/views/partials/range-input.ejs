<div class="range-field" style="position:relative;">
  <div class="grid-2">
    <div>
      <label>Date de début</label>
      <div class="date-field">
        <input type="text" class="date-display range-display range-start" placeholder="JJ/MM/AAAA" autocomplete="off" readonly
          value="<%= locals.debut ? formatDate(locals.debut) : '' %>">
        <svg class="date-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M3 10h18M8 3v4M16 3v4"></path></svg>
      </div>
    </div>
    <div>
      <label>Date de fin</label>
      <div class="date-field">
        <input type="text" class="date-display range-display range-end" placeholder="JJ/MM/AAAA" autocomplete="off" readonly
          value="<%= locals.fin ? formatDate(locals.fin) : '' %>">
        <svg class="date-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M3 10h18M8 3v4M16 3v4"></path></svg>
      </div>
    </div>
  </div>
  <input type="hidden" name="<%= debutName %>" class="range-value-start" value="<%= locals.debut || '' %>">
  <input type="hidden" name="<%= finName %>" class="range-value-end" value="<%= locals.fin || '' %>">
</div>
