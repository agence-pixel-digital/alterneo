<%- include('partials/header', { title: 'Fiches de paie', active: 'paie' }) %>

<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <h3 style="margin:0;">Dépôts récents</h3>
    <button type="button" class="btn btn-primary" onclick="document.getElementById('modal-ajouter-paie').style.display='flex'">+ Ajouter</button>
  </div>
  <% if (recent.length === 0) { %>
    <div class="empty-state">Aucun dépôt pour l'instant.</div>
  <% } else { %>
    <% recent.forEach(function(p) { %>
      <div class="list-row">
        <div class="avatar" style="background:<%= p.profiles.avatar_color %>;">
          <%= (p.profiles.prenom[0] + p.profiles.nom[0]).toUpperCase() %>
        </div>
        <div style="flex:1;">
          <div style="font-size:13.5px;font-weight:600;"><%= p.profiles.prenom %> <%= p.profiles.nom %></div>
          <div style="font-size:12px;color:#9AA7B5;"><%= formatPeriode(p.periode) %></div>
        </div>
        <div style="font-size:12px;color:#9AA7B5;">Déposé le <%= formatDate(p.date_depot) %></div>
      </div>
    <% }); %>
  <% } %>
</div>

<div id="modal-ajouter-paie" class="modal-overlay" style="display:<%= error ? 'flex' : 'none' %>;">
  <div class="modal-box">
    <div class="modal-box-header">
      <h3 style="margin:0;">Déposer une fiche de paie</h3>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-ajouter-paie').style.display='none'">✕</button>
    </div>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="POST" action="/paie" enctype="multipart/form-data">
      <label>Alternant</label>
      <%- include('partials/select-field', { name: 'alternant_id', options: alternants.map(a => ({ value: a.id, label: a.prenom + ' ' + a.nom })) }) %>
      <label>Période (mois)</label>
      <%- include('partials/month-input', { name: 'periode' }) %>
      <div class="upload-zone">
        <input type="file" name="fichier" accept="application/pdf" required>
        <span>PDF, max 5 Mo</span>
      </div>
      <button class="btn btn-primary" type="submit" style="width:100%;">Déposer et notifier</button>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
